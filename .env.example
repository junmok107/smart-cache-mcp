# ---- PostgreSQL ----
POSTGRES_USER=smartcache
POSTGRES_PASSWORD=changeme
POSTGRES_DB=smart_cache_mcp
# Host-side published port only (container-internal port stays 5432, see
# docker-compose.yml). Deliberately non-default: on Windows + Docker Desktop
# (WSL2), a locally-installed PostgreSQL service can silently "win" the
# standard 5432/5433 ports even while `docker compose ps` shows them mapped
# — connections to localhost then reach the native service instead of the
# container. Picking an unusual port avoids the clash entirely.
POSTGRES_PORT=15432
# Full connection string used by mcp-server INSIDE docker-compose (host must
# match the compose service name; port is the container-internal 5432).
DATABASE_URL=postgresql://smartcache:changeme@postgres:5432/smart_cache_mcp
# For local dev running mcp-server OUTSIDE docker (npm run dev), use instead:
# DATABASE_URL=postgresql://smartcache:changeme@localhost:15432/smart_cache_mcp

# ---- MCP Server (Node.js / TypeScript) ----
MCP_SERVER_PORT=3000
NODE_ENV=development
LOG_LEVEL=info
# Optional bearer-token auth for the 5 MCP tools (off when unset). Every
# tool call must then include a matching "_auth" argument. Set this before
# exposing the server beyond localhost.
# MCP_AUTH_TOKEN=

# ---- Embedding Service (Python / FastAPI) ----
EMBEDDING_SERVICE_URL=http://embedding-service:8000
EMBEDDING_SERVICE_PORT=8000
EMBEDDING_MODEL_NAME=intfloat/multilingual-e5-base
# Cross-encoder used for retrieve-then-rerank (stage 2 of cache matching,
# see CLAUDE.md "reranking"). Multilingual so it also helps the cross-lingual
# case the bi-encoder alone sometimes misses. Empirically chosen over smaller
# MS-MARCO-style rerankers, which score topical relevance rather than
# equivalence and badly false-positive on JSON args that differ only in a
# field value (see CLAUDE.md for the numbers).
RERANK_MODEL_NAME=BAAI/bge-reranker-v2-m3
# cuda (RTX 3060 8GB) or cpu
EMBEDDING_DEVICE=cuda

# ---- Cache behavior (defaults; can be changed at runtime via cache_config) ----
# Stage 1 (HNSW cosine retrieval) threshold. Only used as the decision gate
# when the reranker is unreachable — see CACHE_RERANK_THRESHOLD below for the
# value that normally decides hit/miss.
CACHE_SIMILARITY_THRESHOLD=0.90
# Stage 2 (cross-encoder) score threshold — this is what actually decides
# hit/miss in the common case. 0.60 empirically separates true matches
# (identical/paraphrase/cross-lingual, observed ~0.72-0.73) from false
# positives (same tool, different argument value, observed ~0.50-0.51).
CACHE_RERANK_THRESHOLD=0.60
# How many top-K cosine candidates get passed to the reranker per lookup.
CACHE_RERANK_TOP_K=5
CACHE_MAX_ENTRIES=50000
CACHE_MAX_SIZE_MB=256

# TTL per importance level, in seconds: 1=5min, 2=30min, 3=2h, 4=24h, 5=48h
CACHE_TTL_IMPORTANCE_1=300
CACHE_TTL_IMPORTANCE_2=1800
CACHE_TTL_IMPORTANCE_3=7200
CACHE_TTL_IMPORTANCE_4=86400
CACHE_TTL_IMPORTANCE_5=172800
